# Database — PostgreSQL (Supabase or local)
#
# --- Supabase (recommended for production / Hostinger) ---
# 1. Open https://supabase.com → your project → Project Settings → Database
# 2. Copy the password you set when creating the project (or reset it)
# 3. Under "Connection string" choose URI, mode: "Direct connection" (port 5432)
# 4. Replace [YOUR-PASSWORD] and ensure the host matches your project ref
#
# Example (replace YOUR_PASSWORD and YOUR_PROJECT_REF):
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
#
# Session pooler (port 6543) is for many short-lived clients; this Node app usually uses Direct (5432) above.
#
# --- Local PostgreSQL ---
# DATABASE_URL="postgresql://user:password@localhost:5432/kings_aqomplice"

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Server
PORT=3000
NODE_ENV=development

# Security (generate strong values for production)
JWT_SECRET=change-this-to-a-secure-random-string
CSRF_SECRET=change-this-to-a-secure-random-string

# AI (optional - chat works without it, returns fallback message)
OPENAI_API_KEY=

# Admin: set to false on production to disable public self-registration at /admin/register
# ALLOW_ADMIN_REGISTRATION=false
