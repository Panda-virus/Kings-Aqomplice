{
  "name": "kings-aqomplice",
  "version": "1.0.0",
  "description": "Legal intelligence platform for Kings Aqomplice",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lordsi/Kings-Aqomplice-.git"
  },
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "build:css": "tailwindcss -i ./src/css/input.css -o ./www/css/styles.css --minify",
    "build": "npm run build:css && npm run build:icons",
    "build:icons": "node scripts/generate-icons.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "seed:admin": "node scripts/seed-admin.js",
    "seed:team": "node scripts/seed-team-admins.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "openai": "^4.73.0",
    "prisma": "^5.22.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14"
  }
}
